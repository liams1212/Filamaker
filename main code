# ===== כיול טמפרטורה =====
T_ROOM = 25.0
K_SCALE = 100.0 / 130.0  # אם צריך עוד דיוק – נשחק בזה

def read_temp():
    """
    קריאת NTC 100k עם נגד 100k וטמפ' מתוקננת.
    """
    global current_temp

    samples = 0
    N = 8
    for _ in range(N):
        samples += adc.read()
    raw = samples // N

    if raw <= 0 or raw >= 4094:
        return current_temp

    R_SERIES = 100000.0
    v_ratio = raw / 4095.0
    if v_ratio <= 0.0 or v_ratio >= 1.0:
        return current_temp

    R_ntc = R_SERIES * v_ratio / (1.0 - v_ratio)

    R0 = 100000.0
    T0 = 25.0 + 273.15
    B  = 3950.0

    if R_ntc <= 0:
        return current_temp

    invT = (1.0 / T0) + (1.0 / B) * math.log(R_ntc / R0)
    T = 1.0 / invT
    temp_c = T - 273.15

    # כיול – דחיסת סקאלה
    temp_c = T_ROOM + (temp_c - T_ROOM) * K_SCALE

    if temp_c < 0:
        temp_c = 0
    if temp_c > 300:
        temp_c = 300

    return int(temp_c)

