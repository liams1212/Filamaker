PIX = 2  # סקייל ברירת מחדל ל-UI

def draw_char(ch,x,y,color):
    ch = ch.upper()
    if ch not in FONT:
        return
    rows = FONT[ch]
    for r in range(7):
        bits = rows[r]
        for c in range(5):
            if (bits >> (4 - c)) & 1:
                tft.fill_rect(x + c*PIX, y + r*PIX, PIX, PIX, color)

def draw_text(text,x,y,color):
    for ch in text:
        if ch == " ":
            x += 12
        else:
            draw_char(ch,x,y,color)
            x += 12

# ========= פונקציות לטקסט גדול (רק לספלש) =========
def draw_char_scaled(ch, x, y, color, scale):
    ch = ch.upper()
    if ch not in FONT:
        return
    rows = FONT[ch]
    for r in range(7):
        bits = rows[r]
        for c in range(5):
            if (bits >> (4 - c)) & 1:
                tft.fill_rect(x + c*scale, y + r*scale, scale, scale, color)

def draw_text_scaled(text, x, y, color, scale):
    for ch in text:
        if ch == " ":
            x += (5 + 2) * scale
        else:
            draw_char_scaled(ch, x, y, color, scale)
            x += (5 + 2) * scale

# =====================================================
#   FRAME
# =====================================================
def frame(x,y,w,h):
    tft.fill_rect(x,y,w,2,WHITE)
    tft.fill_rect(x,y+h-2,w,2,WHITE)
    tft.fill_rect(x,y,2,h,WHITE)
    tft.fill_rect(x+w-2,y,2,h,WHITE)

# =====================================================
#   HEAT / COOL ICONS (בעמוד טמפרטורה)
# =====================================================
ICON_X = 320
ICON_Y = 180
ICON_W = 80
ICON_H = 60

last_icon_state = None  # "OFF" / "HEAT" / "COOL"

def draw_heating_icon():
    # clear area
    tft.fill_rect(ICON_X, ICON_Y, ICON_W, ICON_H, BLACK)
    # three "heat waves"
    for i in range(3):
        base_x = ICON_X + 10 + i*15
        for j in range(6):
            dx = j % 2
            tft.fill_rect(base_x+dx, ICON_Y+5+j*6, 3, 5, RED)

def draw_cooling_icon():
    tft.fill_rect(ICON_X, ICON_Y, ICON_W, ICON_H, BLACK)
    # small ice cube
    x = ICON_X + 20
    y = ICON_Y + 10
    size = 30
    # border
    tft.fill_rect(x, y, size, 2, WHITE)
    tft.fill_rect(x, y+size-2, size, 2, WHITE)
    tft.fill_rect(x, y, 2, size, WHITE)
    tft.fill_rect(x+size-2, y, 2, size, WHITE)
    # inside
    tft.fill_rect(x+3, y+3, size-6, size-6, BLUE)
    # cross
    tft.fill_rect(x+size//2-1, y+5, 2, size-10, WHITE)
    tft.fill_rect(x+5, y+size//2-1, size-10, 2, WHITE)

def clear_icon():
    tft.fill_rect(ICON_X, ICON_Y, ICON_W, ICON_H, BLACK)

def update_heat_icon():
    global last_icon_state
    if not heater_enabled:
        icon_state = "OFF"
    else:
        if heater_output:
            icon_state = "HEAT"
        else:
            icon_state = "COOL"

    if icon_state == last_icon_state:
        return

    if icon_state == "OFF":
        clear_icon()
    elif icon_state == "HEAT":
        draw_heating_icon()
    else:
        draw_cooling_icon()

    last_icon_state = icon_state

# =====================================================
#   MAIN MENU + טמפרטורה במסך הבית
# =====================================================
item_x = 20
item_w = 440
item_h = 60
item0_y = 80
item1_y = 160

last_home_temp = None

def update_home_temp(force=False):
    """
    במסך הבית – רק המספר מתעדכן, לא כל השורה.
    TEMP: ... C נצייר פעם אחת, ואח"כ רק המספר.
    """
    global last_home_temp

    if state != STATE_MENU:
        return
    if (not force) and (last_home_temp == current_temp):
        return

    # מעדכן רק את המספר (אזור קטן)
    tft.fill_rect(320, 55, 60, 25, BLACK)
    draw_text(str(current_temp), 320, 55, WHITE)

    last_home_temp = current_temp

def draw_menu():
    global last_menu_index, last_home_temp, state

    state = STATE_MENU
    tft.fill(BLACK)

    tft.fill_rect(0,0,480,50,CYAN)
    frame(0,0,480,50)
    draw_text("MAIN MENU", 20, 14, BLACK)

    # שורת TEMP קבועה – טקסט פעם אחת
    draw_text("TEMP:", 240, 55, WHITE)
    draw_text("C",     400, 55, WHITE)

    tft.fill_rect(item_x,item0_y,item_w,item_h,BLUE)
    draw_text("MOTOR SPEED", item_x+30, item0_y+18, WHITE)

    tft.fill_rect(item_x,item1_y,item_w,item_h,BLUE)
    draw_text("TEMPERATURE", item_x+30, item1_y+18, WHITE)

    last_menu_index = None
    last_home_temp = None
    update_home_temp(True)

def highlight_menu(i):
    global last_menu_index

    if i == last_menu_index:
        return

    tft.fill_rect(item_x,item0_y,item_w,item_h,BLUE)
    draw_text("MOTOR SPEED", item_x+30, item0_y+18, WHITE)

    tft.fill_rect(item_x,item1_y,item_w,item_h,BLUE)
    draw_text("TEMPERATURE", item_x+30, item1_y+18, WHITE)

    if i == 0:
        frame(item_x,item0_y,item_w,item_h)
    else:
        frame(item_x,item1_y,item_w,item_h)

    last_menu_index = i

