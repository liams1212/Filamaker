#   TEMP SCREEN
# =====================================================
last_set  = None
last_cur  = None
last_heat = None

def draw_temp_screen():
    global state, last_set, last_cur, last_heat, last_icon_state
    state = STATE_TEMP

    tft.fill(BLACK)

    tft.fill_rect(0,0,480,40,BLUE)
    frame(0,0,480,40)
    draw_text("TEMPERATURE",10,8,WHITE)

    draw_text("SET:",  40, 80, WHITE)
    draw_text("CUR:",  40,140, WHITE)
    draw_text("HEAT:", 40,200, WHITE)
    draw_text("BTN:TOGGLE  HOLD:MENU",40,260,WHITE)

    last_set  = None
    last_cur  = None
    last_heat = None
    last_icon_state = None

    update_temp_screen(True)

def update_temp_screen(force=False):
    global last_set, last_cur, last_heat

    if force or last_set != temp_value:
        tft.fill_rect(140,80,200,30,BLACK)
        draw_text(str(temp_value),140,80,WHITE)
        draw_text("C",260,80,WHITE)
        last_set = temp_value

    if force or last_cur != current_temp:
        tft.fill_rect(140,140,200,30,BLACK)
        draw_text(str(current_temp),140,140,WHITE)
        draw_text("C",260,140,WHITE)
        last_cur = current_temp

    hs = "ON" if heater_enabled else "OFF"
    if force or hs != last_heat:
        tft.fill_rect(140,200,200,30,BLACK)
        draw_text(hs,140,200,WHITE)
        last_heat = hs

    # לעדכן אייקון חימום/קירור
    update_heat_icon()

def enter_temp():
    draw_temp_screen()

# =====================================================
#   SPLASH SCREEN – FILAMAKER גדול ובאמצע
# =====================================================
def splash_screen():
    tft.fill(BLACK)
    text = "FILAMAKER"
    scale = 4  # כמה גדול
    char_w = 5
    spacing = 2
    text_width = len(text) * (char_w + spacing) * scale
    text_height = 7 * scale

    x = (480 - text_width) // 2
    y = (320 - text_height) // 2

    draw_text_scaled(text, x, y, BLUE, scale)
    time.sleep_ms(1500)

# =====================================================
#   BUTTON STATE (לא חוסם)
# =====================================================
btn_prev = 1
btn_down_time = None

# =====================================================
#   STARTUP
# =====================================================
splash_screen()
draw_menu()
highlight_menu(menu_index)

# =====================================================
#   MAIN LOOP
# =====================================================
while True:

    now = time.ticks_ms()

    # -------- ENCODER ROTATION --------
    c = clk.value()
    if last_clk == 1 and c == 0:
        direction = 1 if dt.value() else -1

        if state == STATE_MENU:
            menu_index += direction
            if menu_index < 0:
                menu_index = 0
            if menu_index > 1:
                menu_index = 1
            highlight_menu(menu_index)

        elif state == STATE_SPEED:
            speed_value += direction * STEP_SPEED
            if speed_value < 0:
                speed_value = 0
            if speed_value > 100:
                speed_value = 100
            update_speed()

        elif state == STATE_TEMP:
            temp_value += direction * STEP_TEMP
            if temp_value < 0:
                temp_value = 0
            if temp_value > 300:
                temp_value = 300
            update_temp_screen()

    last_clk = c

    # -------- BUTTON (ללא while) --------
    sw_val = sw.value()
    if sw_val == 0 and btn_prev == 1:
        btn_down_time = now

    if sw_val == 1 and btn_prev == 0 and btn_down_time is not None:
        press_ms = time.ticks_diff(now, btn_down_time)

        if state == STATE_MENU:
            if menu_index == 0:
                enter_speed()
            else:
                enter_temp()

        elif state == STATE_SPEED:
            if press_ms < 600:
                # שינוי כיוון
                DIR_STATE = 1 - DIR_STATE
                DIR.value(DIR_STATE)
                update_speed()
            else:
                # חזרה לתפריט
                state = STATE_MENU
                draw_menu()
                highlight_menu(menu_index)

        elif state == STATE_TEMP:
            if press_ms < 600:
                # הדלקה/כיבוי חימום
                heater_enabled = not heater_enabled
                update_temp_screen()
            else:
                # חזרה לתפריט
                state = STATE_MENU
                draw_menu()
                highlight_menu(menu_index)

        btn_down_time = None

    btn_prev = sw_val

    # -------- TEMP READ --------
    if time.ticks_diff(now,last_temp_ms) >= TEMP_INTERVAL:
        last_temp_ms = now
        current_temp = read_temp()
        if state == STATE_TEMP:
            update_temp_screen()
        # עדכון טמפ' במסך הבית (רק המספר)
        update_home_temp()

    # -------- HEATER CONTROL --------
    if time.ticks_diff(now,last_heat_ms) >= HEAT_INTERVAL:
        last_heat_ms = now

        if heater_enabled:
            if current_temp < temp_value - TEMP_HYST:
                heater_output = 1
            elif current_temp > temp_value + TEMP_HYST:
                heater_output = 0
        else:
            heater_output = 0

        HEATER.value(heater_output)

    # -------- MOTOR RAMP --------
    if time.ticks_diff(now,last_ramp_ms) >= 10:
        if motor_speed < speed_value:
            motor_speed += 1
        elif motor_speed > speed_value:
            motor_speed -= 1
        last_ramp_ms = now

    # -------- STEPPER CONTROL דרך PWM --------
    if motor_speed > 0:
        EN.value(0)
        if motor_speed != prev_motor_speed:
            ratio = motor_speed / 100.0
            freq = int(1000 + (6000 - 1000) * ratio)
            if freq < 100:
                freq = 100
            pwm_step.freq(freq)
            pwm_step.duty_u16(32768)
            prev_motor_speed = motor_speed
    else:
        if prev_motor_speed != 0:
            pwm_step.duty_u16(0)
            EN.value(1)
            prev_motor_speed = 0

    time.sleep_us(50)
