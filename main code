    state = STATE_SPEED

    tft.fill(BLACK)
    tft.fill_rect(0,0,480,40,BLUE)
    frame(0,0,480,40)
    draw_text("MOTOR SPEED",10,8,WHITE)

    draw_text("SPEED",40,80,WHITE)
    draw_text("PCT",300,80,WHITE)
    draw_text("DIR:",40,130,WHITE)
    draw_text("BTN:DIR  HOLD:MENU",40,200,WHITE)

    update_speed()

def update_speed():
    tft.fill_rect(180,80,150,30,BLACK)
    draw_text(str(speed_value),180,80,WHITE)

    d = "FWD" if DIR_STATE == 0 else "REV"
    tft.fill_rect(120,130,150,30,BLACK)
    draw_text(d,120,130,WHITE)

def enter_speed():
    draw_speed_screen()

